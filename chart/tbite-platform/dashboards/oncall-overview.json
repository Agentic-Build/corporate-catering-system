{
  "annotations": {
    "list": []
  },
  "description": "Layer 1 \u2014 Service Health (broad view). Start at /d/status for the headline; drop in here for HTTP RED, infrastructure saturation, and domain rollups side-by-side.",
  "editable": false,
  "graphTooltip": 1,
  "id": null,
  "links": [
    {
      "title": "System Status",
      "type": "link",
      "url": "/d/status",
      "icon": "external link",
      "targetBlank": false
    },
    {
      "title": "Detail dashboards",
      "type": "dashboards",
      "tags": [
        "domain",
        "platform",
        "infra"
      ],
      "asDropdown": true,
      "icon": "external link"
    }
  ],
  "panels": [
    {
      "type": "stat",
      "title": "Services up",
      "datasource": {
        "type": "prometheus",
        "uid": "VictoriaMetrics"
      },
      "gridPos": {
        "h": 4,
        "w": 24,
        "x": 0,
        "y": 0
      },
      "fieldConfig": {
        "defaults": {
          "mappings": [
            {
              "options": {
                "0": {
                  "color": "red",
                  "text": "DOWN"
                }
              },
              "type": "value"
            },
            {
              "options": {
                "1": {
                  "color": "green",
                  "text": "UP"
                }
              },
              "type": "value"
            }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red"
              },
              {
                "color": "green",
                "value": 1
              }
            ]
          }
        }
      },
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center",
        "textMode": "value_and_name",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        }
      },
      "targets": [
        {
          "expr": "up{job=~\".*otelcol.*\"}",
          "legendFormat": "OTel",
          "refId": "A"
        },
        {
          "expr": "up{job=~\".*vmsingle\"}",
          "legendFormat": "VM",
          "refId": "B"
        },
        {
          "expr": "up{job=~\".*victoria-logs\"}",
          "legendFormat": "VL",
          "refId": "C"
        },
        {
          "expr": "up{job=~\".*victoria-traces\"}",
          "legendFormat": "VT",
          "refId": "D"
        },
        {
          "expr": "clamp_max(count(cnpg_collector_up == 1), 1) or on() vector(0)",
          "legendFormat": "Postgres",
          "refId": "E"
        },
        {
          "expr": "clamp_max(count(up{job=~\".*valkey.*\"} == 1), 1) or on() vector(0)",
          "legendFormat": "Redis",
          "refId": "F"
        },
        {
          "expr": "clamp_max(count(nats_server_jetstream_disabled == 0), 1) or on() vector(0)",
          "legendFormat": "NATS broker",
          "refId": "G"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "HTTP request rate by route (top 10)",
      "datasource": {
        "type": "prometheus",
        "uid": "VictoriaMetrics"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 4
      },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 10,
            "showPoints": "never"
          }
        }
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": [
            "mean",
            "max"
          ]
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "targets": [
        {
          "expr": "topk(10, sum by (http_route) (rate(http_server_request_duration_seconds_count{deployment_environment=~\"$env\"}[5m])))",
          "legendFormat": "{{http_route}}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "HTTP error rate (5xx) by route",
      "datasource": {
        "type": "prometheus",
        "uid": "VictoriaMetrics"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 4
      },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 10,
            "showPoints": "never"
          },
          "color": {
            "mode": "palette-classic"
          }
        }
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": [
            "sum"
          ]
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "targets": [
        {
          "expr": "topk(10, sum by (http_route) (rate(http_server_request_duration_seconds_count{deployment_environment=~\"$env\",http_response_status_code=~\"5..\"}[5m])))",
          "legendFormat": "{{http_route}}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "HTTP p95 latency by route (top 10)",
      "datasource": {
        "type": "prometheus",
        "uid": "VictoriaMetrics"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 12
      },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 10,
            "showPoints": "never"
          }
        }
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": [
            "mean",
            "max"
          ]
        }
      },
      "targets": [
        {
          "expr": "topk(10, histogram_quantile(0.95, sum by (le, http_route) (rate(http_server_request_duration_seconds_bucket{deployment_environment=~\"$env\"}[5m]))))",
          "legendFormat": "{{http_route}}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Postgres pool \u2014 active vs idle connections",
      "datasource": {
        "type": "prometheus",
        "uid": "VictoriaMetrics"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 12
      },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 20,
            "showPoints": "never",
            "stacking": {
              "mode": "normal"
            }
          }
        }
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        }
      },
      "targets": [
        {
          "expr": "sum(cnpg_backends_total{datname=\"tbite\",state=\"active\"})",
          "legendFormat": "active",
          "refId": "A"
        },
        {
          "expr": "sum(cnpg_backends_total{datname=\"tbite\",state=\"idle\"})",
          "legendFormat": "idle",
          "refId": "B"
        },
        {
          "expr": "sum(cnpg_backends_total{datname=\"tbite\",state=\"idle in transaction\"})",
          "legendFormat": "idle in tx",
          "refId": "C"
        }
      ]
    },
    {
      "type": "stat",
      "title": "Place-order success ratio (5m)",
      "description": "Single-number health KPI: success / total over the last 5 minutes. Green ≥ 0.95, yellow ≥ 0.80, red below. Complements the by-outcome stacked timeseries in the catering-domain section — that one shows the breakdown, this one shows whether the headline is healthy.",
      "datasource": {
        "type": "prometheus",
        "uid": "VictoriaMetrics"
      },
      "gridPos": {
        "h": 6,
        "w": 12,
        "x": 0,
        "y": 20
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "red", "value": null},
              {"color": "yellow", "value": 0.80},
              {"color": "green", "value": 0.95}
            ]
          }
        }
      },
      "options": {
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "colorMode": "background",
        "graphMode": "area",
        "textMode": "auto",
        "justifyMode": "center"
      },
      "targets": [
        {
          "expr": "sum(rate(catering_order_placed_count_total{deployment_environment=~\"$env\",outcome=\"success\"}[5m])) / clamp_min(sum(rate(catering_order_placed_count_total{deployment_environment=~\"$env\"}[5m])), 1e-9)",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Async-plane backlog (publisher + consumers)",
      "description": "Three complementary backlog signals on one chart so the L1 dashboard distinguishes WHERE the async plane is unhealthy: outbox_pending (DB rows the publisher has not yet flushed to NATS — climbs when outbox-relay is dead or slow), jetstream consumer_pending (messages in NATS that consumers have not yet acked — climbs when a downstream worker stalls), and dlq_pending (events that failed all retries). If only the publisher curve climbs the broker pump is the suspect; if only consumers climb, drill into the async-plane detail dashboard.",
      "datasource": {
        "type": "prometheus",
        "uid": "VictoriaMetrics"
      },
      "gridPos": {
        "h": 6,
        "w": 12,
        "x": 12,
        "y": 20
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 10,
            "showPoints": "never"
          }
        },
        "overrides": [
          {
            "matcher": {"id": "byName", "options": "outbox_pending (publisher)"},
            "properties": [{"id": "color", "value": {"mode": "fixed", "fixedColor": "red"}}]
          },
          {
            "matcher": {"id": "byName", "options": "dlq_pending"},
            "properties": [{"id": "color", "value": {"mode": "fixed", "fixedColor": "dark-red"}}]
          }
        ]
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": ["mean", "max"]
        }
      },
      "targets": [
        {
          "expr": "sum(tbite_outbox_pending) or vector(0)",
          "legendFormat": "outbox_pending (publisher)",
          "refId": "A"
        },
        {
          "expr": "sum(tbite_dlq_pending) or vector(0)",
          "legendFormat": "dlq_pending",
          "refId": "B"
        },
        {
          "expr": "sum by (consumer_name) (nats_consumer_num_pending{consumer_name=~\"on-time-evaluator|payroll-settler|outbox-relay.*\"})",
          "legendFormat": "consumer:{{consumer_name}}",
          "refId": "C"
        }
      ]
    },
    {
      "type": "row",
      "title": "Catering domain \u2014 what's the system actually doing?",
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 26
      },
      "collapsed": false
    },
    {
      "type": "timeseries",
      "title": "Order placement \u2014 outcome (stacked)",
      "datasource": {
        "type": "prometheus",
        "uid": "VictoriaMetrics"
      },
      "gridPos": {
        "h": 8,
        "w": 24,
        "x": 0,
        "y": 27
      },
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "custom": {
            "drawStyle": "bars",
            "fillOpacity": 80,
            "showPoints": "never",
            "stacking": {
              "mode": "normal"
            }
          }
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "success"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "mode": "fixed",
                  "fixedColor": "green"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "quota_exhausted"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "mode": "fixed",
                  "fixedColor": "red"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "cutoff_passed"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "mode": "fixed",
                  "fixedColor": "orange"
                }
              }
            ]
          }
        ]
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        }
      },
      "targets": [
        {
          "expr": "sum by (outcome) (rate(catering_order_placed_count_total{deployment_environment=~\"$env\"}[1m]))",
          "legendFormat": "{{outcome}}",
          "refId": "A"
        }
      ],
      "links": [
        {
          "title": "Order Lifecycle",
          "url": "/d/order-lifecycle"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Cancel / modify rate",
      "datasource": {
        "type": "prometheus",
        "uid": "VictoriaMetrics"
      },
      "gridPos": {
        "h": 7,
        "w": 12,
        "x": 0,
        "y": 35
      },
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 10,
            "showPoints": "never"
          }
        }
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        }
      },
      "targets": [
        {
          "expr": "sum(rate(catering_order_cancelled_count_total[1m]))",
          "legendFormat": "cancel/s",
          "refId": "A"
        },
        {
          "expr": "sum(rate(catering_order_modified_count_total[1m]))",
          "legendFormat": "modify/s",
          "refId": "B"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Supply adjustments by direction",
      "datasource": {
        "type": "prometheus",
        "uid": "VictoriaMetrics"
      },
      "gridPos": {
        "h": 7,
        "w": 12,
        "x": 12,
        "y": 35
      },
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 10,
            "showPoints": "never"
          }
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "up"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "mode": "fixed",
                  "fixedColor": "green"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "down"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "mode": "fixed",
                  "fixedColor": "red"
                }
              }
            ]
          }
        ]
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        }
      },
      "targets": [
        {
          "expr": "sum by (direction) (rate(catering_supply_adjusted_count_total[1m]))",
          "legendFormat": "{{direction}}",
          "refId": "A"
        }
      ]
    }
  ],
  "refresh": "30s",
  "schemaVersion": 39,
  "tags": [
    "oncall",
    "overview"
  ],
  "templating": {
    "list": [
      {
        "name": "env",
        "type": "custom",
        "label": "Environment",
        "options": [
          {
            "text": "all",
            "value": ".*",
            "selected": true
          },
          {
            "text": "development",
            "value": "development"
          },
          {
            "text": "production",
            "value": "production"
          }
        ],
        "current": {
          "text": "all",
          "value": ".*"
        }
      }
    ]
  },
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "timezone": "browser",
  "title": "Service Health (Layer 1)",
  "uid": "oncall-overview",
  "version": 1
}
