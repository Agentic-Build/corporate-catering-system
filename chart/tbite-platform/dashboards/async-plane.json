{
  "annotations": {
    "list": []
  },
  "description": "Async plane health \u2014 NATS JetStream throughput, consumer lag, DLQ depth, outbox lag. NATS metrics come from the NATS prometheus exporter; DLQ + outbox metrics are emitted by the API via OpenTelemetry.",
  "editable": false,
  "graphTooltip": 1,
  "id": null,
  "panels": [
    {
      "type": "row",
      "title": "NATS JetStream",
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 0
      },
      "collapsed": false
    },
    {
      "type": "timeseries",
      "title": "Stream messages in/out (rate)",
      "datasource": {
        "type": "prometheus",
        "uid": "VictoriaMetrics"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 1
      },
      "fieldConfig": {
        "defaults": {
          "unit": "mps",
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 10,
            "showPoints": "never"
          }
        }
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": [
            "mean",
            "max"
          ]
        }
      },
      "targets": [
        {
          "expr": "sum by (stream_name) (rate(nats_stream_last_seq[1m]))",
          "legendFormat": "in {{stream_name}}",
          "refId": "A"
        },
        {
          "expr": "sum by (stream_name) (rate(nats_stream_first_seq[1m]))",
          "legendFormat": "consumed {{stream_name}}",
          "refId": "B"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Consumer pending \u2014 top 10",
      "datasource": {
        "type": "prometheus",
        "uid": "VictoriaMetrics"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 1
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 10,
            "showPoints": "never"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green"
              },
              {
                "color": "yellow",
                "value": 100
              },
              {
                "color": "red",
                "value": 1000
              }
            ]
          }
        }
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": [
            "max"
          ]
        }
      },
      "targets": [
        {
          "expr": "topk(10, nats_consumer_num_pending{consumer_name=~\"on-time-evaluator|payroll-settler|outbox-relay.*\"})",
          "legendFormat": "{{stream_name}}/{{consumer_name}}",
          "refId": "A"
        }
      ],
      "description": "Lag concern is meaningful only for ack-tracked worker consumers (AckExplicit). board-fanout, mcp-watchers, and orphaned anonymous consumers from past API restarts are AckNonePolicy fire-and-forget — their num_pending tracks publish rate not lag. This panel whitelists the durable worker consumers we care about."
    },
    {
      "type": "timeseries",
      "title": "Consumer redeliveries",
      "datasource": {
        "type": "prometheus",
        "uid": "VictoriaMetrics"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 9
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 10,
            "showPoints": "never"
          }
        }
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": [
            "sum"
          ]
        }
      },
      "targets": [
        {
          "expr": "sum by (stream_name, consumer_name) (nats_consumer_num_redelivered)",
          "legendFormat": "{{stream_name}}/{{consumer_name}}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Stream storage bytes",
      "datasource": {
        "type": "prometheus",
        "uid": "VictoriaMetrics"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 9
      },
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 10,
            "showPoints": "never"
          }
        }
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": [
            "last"
          ]
        }
      },
      "targets": [
        {
          "expr": "nats_stream_total_bytes",
          "legendFormat": "{{stream_name}}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "row",
      "title": "Outbox + DLQ",
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 17
      },
      "collapsed": false
    },
    {
      "type": "stat",
      "title": "DLQ pending",
      "datasource": {
        "type": "prometheus",
        "uid": "VictoriaMetrics"
      },
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 0,
        "y": 18
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "noValue": "0",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green"
              },
              {
                "color": "yellow",
                "value": 10
              },
              {
                "color": "red",
                "value": 100
              }
            ]
          }
        }
      },
      "options": {
        "colorMode": "background",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        }
      },
      "targets": [
        {
          "expr": "sum(tbite_dlq_pending)",
          "refId": "A"
        }
      ]
    },
    {
      "type": "stat",
      "title": "DLQ oldest unresolved",
      "datasource": {
        "type": "prometheus",
        "uid": "VictoriaMetrics"
      },
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 6,
        "y": 18
      },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "noValue": "0",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green"
              },
              {
                "color": "yellow",
                "value": 900
              },
              {
                "color": "red",
                "value": 3600
              }
            ]
          }
        }
      },
      "options": {
        "colorMode": "background",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        }
      },
      "targets": [
        {
          "expr": "max(tbite_dlq_oldest_seconds)",
          "refId": "A"
        }
      ]
    },
    {
      "type": "stat",
      "title": "Outbox pending",
      "datasource": {
        "type": "prometheus",
        "uid": "VictoriaMetrics"
      },
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 12,
        "y": 18
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "noValue": "0",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green"
              },
              {
                "color": "yellow",
                "value": 50
              },
              {
                "color": "red",
                "value": 500
              }
            ]
          }
        }
      },
      "options": {
        "colorMode": "background",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        }
      },
      "targets": [
        {
          "expr": "sum(tbite_outbox_pending)",
          "refId": "A"
        }
      ]
    },
    {
      "type": "stat",
      "title": "Outbox oldest unpublished",
      "datasource": {
        "type": "prometheus",
        "uid": "VictoriaMetrics"
      },
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 18,
        "y": 18
      },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "noValue": "0",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green"
              },
              {
                "color": "yellow",
                "value": 60
              },
              {
                "color": "red",
                "value": 600
              }
            ]
          }
        }
      },
      "options": {
        "colorMode": "background",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        }
      },
      "targets": [
        {
          "expr": "max(tbite_outbox_oldest_seconds)",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "DLQ + outbox pending over time",
      "datasource": {
        "type": "prometheus",
        "uid": "VictoriaMetrics"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 22
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 10,
            "showPoints": "never"
          }
        }
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": [
            "mean",
            "max"
          ]
        }
      },
      "targets": [
        {
          "expr": "sum by (source_stream) (tbite_dlq_pending)",
          "legendFormat": "dlq {{source_stream}}",
          "refId": "A"
        },
        {
          "expr": "sum by (aggregate_type) (tbite_outbox_pending)",
          "legendFormat": "outbox {{aggregate_type}}",
          "refId": "B"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Postgres TPS \u2014 order/payroll/settlement tables",
      "datasource": {
        "type": "prometheus",
        "uid": "VictoriaMetrics"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 22
      },
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 10,
            "showPoints": "never"
          }
        }
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        }
      },
      "targets": [
        {
          "expr": "rate(cnpg_pg_stat_database_xact_commit{datname=\"tbite\"}[1m])",
          "legendFormat": "commits/s",
          "refId": "A"
        },
        {
          "expr": "rate(cnpg_pg_stat_database_xact_rollback{datname=\"tbite\"}[1m])",
          "legendFormat": "rollbacks/s",
          "refId": "B"
        }
      ]
    }
  ],
  "refresh": "30s",
  "schemaVersion": 39,
  "tags": [
    "platform",
    "async"
  ],
  "templating": {
    "list": []
  },
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "timezone": "browser",
  "title": "Async Plane \u2014 NATS + DLQ",
  "uid": "async-plane",
  "version": 1,
  "links": [
    {
      "title": "System Status",
      "type": "link",
      "url": "/d/status",
      "icon": "external link",
      "targetBlank": false
    },
    {
      "title": "Service Health",
      "type": "link",
      "url": "/d/oncall-overview",
      "icon": "external link",
      "targetBlank": false
    }
  ]
}
