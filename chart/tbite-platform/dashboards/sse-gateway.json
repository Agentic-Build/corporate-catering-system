{
  "__inputs": [
    {
      "name": "DS_VICTORIA_METRICS",
      "label": "VictoriaMetrics",
      "description": "VictoriaMetrics (Prometheus-compatible) datasource backing tbite observability.",
      "type": "datasource",
      "pluginId": "prometheus",
      "pluginName": "Prometheus"
    }
  ],
  "__elements": {},
  "__requires": [
    { "type": "grafana", "id": "grafana", "name": "Grafana", "version": "10.0.0" },
    { "type": "datasource", "id": "prometheus", "name": "Prometheus", "version": "1.0.0" },
    { "type": "panel", "id": "timeseries", "name": "Time series", "version": "" },
    { "type": "panel", "id": "stat", "name": "Stat", "version": "" },
    { "type": "panel", "id": "gauge", "name": "Gauge", "version": "" }
  ],
  "annotations": { "list": [] },
  "description": "SSE realtime gateway (architecture baseline issue #56). Active connections per pod, fanout lag, topic subscription count, disconnect rate.",
  "editable": false,
  "graphTooltip": 1,
  "id": null,
  "panels": [
    {
      "type": "row",
      "title": "Connection saturation",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "collapsed": false
    },
    {
      "type": "timeseries",
      "title": "Active SSE connections per pod",
      "datasource": { "type": "prometheus", "uid": "VictoriaMetrics" },
      "gridPos": { "h": 8, "w": 16, "x": 0, "y": 1 },
      "id": 1,
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": { "drawStyle": "line", "fillOpacity": 10, "showPoints": "never" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green" },
              { "color": "yellow", "value": 4000 },
              { "color": "red", "value": 5000 }
            ]
          }
        }
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["max", "mean"] }
      },
      "targets": [
        {
          "expr": "tbite_sse_active_connections",
          "legendFormat": "{{pod}}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "gauge",
      "title": "Hottest pod (% of 5000 cap)",
      "datasource": { "type": "prometheus", "uid": "VictoriaMetrics" },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 1 },
      "id": 2,
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green" },
              { "color": "yellow", "value": 0.8 },
              { "color": "red", "value": 0.95 }
            ]
          }
        }
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] }
      },
      "targets": [
        {
          "expr": "max(tbite_sse_active_connections) / 5000",
          "refId": "A"
        }
      ]
    },
    {
      "type": "row",
      "title": "Fanout latency + topics",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 9 },
      "collapsed": false
    },
    {
      "type": "timeseries",
      "title": "Fanout lag (seconds) by topic",
      "datasource": { "type": "prometheus", "uid": "VictoriaMetrics" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 10 },
      "id": 3,
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": { "drawStyle": "line", "fillOpacity": 10, "showPoints": "never" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green" },
              { "color": "yellow", "value": 2 },
              { "color": "red", "value": 5 }
            ]
          }
        }
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["max", "mean"] }
      },
      "targets": [
        {
          "expr": "tbite_sse_fanout_lag_seconds",
          "legendFormat": "{{topic}}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Subscribers per topic",
      "datasource": { "type": "prometheus", "uid": "VictoriaMetrics" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 10 },
      "id": 4,
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": { "drawStyle": "line", "fillOpacity": 10, "showPoints": "never" }
        }
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["max"] }
      },
      "targets": [
        {
          "expr": "sum by (topic) (tbite_sse_topic_subscribers)",
          "legendFormat": "{{topic}}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Disconnect rate (per reason)",
      "datasource": { "type": "prometheus", "uid": "VictoriaMetrics" },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 18 },
      "id": 5,
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "custom": { "drawStyle": "line", "fillOpacity": 10, "showPoints": "never" }
        }
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "sum"] }
      },
      "targets": [
        {
          "expr": "sum by (reason) (rate(tbite_sse_disconnects_total[5m]))",
          "legendFormat": "{{reason}}",
          "refId": "A"
        }
      ]
    }
  ],
  "refresh": "30s",
  "schemaVersion": 39,
  "tags": ["tbite", "architecture-baseline-47"],
  "templating": { "list": [] },
  "time": { "from": "now-1h", "to": "now" },
  "timezone": "browser",
  "title": "SSE Gateway — Realtime Fanout",
  "uid": "sse-gateway",
  "version": 1
}
