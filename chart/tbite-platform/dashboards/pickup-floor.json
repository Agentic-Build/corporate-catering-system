{
  "annotations": {
    "list": []
  },
  "description": "Pickup floor \u2014 meal-window throughput + TOTP verification health. Surfaces broken QR scanners (high invalid_code rate) and no-show patterns. Layer 2 detail; start at /d/status for top-level.",
  "editable": false,
  "graphTooltip": 1,
  "id": null,
  "links": [
    {
      "title": "\u2605 System Status",
      "type": "link",
      "url": "/d/status",
      "icon": "external link",
      "targetBlank": false
    },
    {
      "title": "\u25c6 Service Health",
      "type": "link",
      "url": "/d/oncall-overview",
      "icon": "external link",
      "targetBlank": false
    }
  ],
  "panels": [
    {
      "type": "stat",
      "title": "Orders marked READY (24h)",
      "datasource": {
        "type": "prometheus",
        "uid": "VictoriaMetrics"
      },
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 0,
        "y": 0
      },
      "description": "Vendor mark-ready operations. Ready \u2192 Pickup gap is operational efficiency.",
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "noValue": "0"
        }
      },
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        }
      },
      "targets": [
        {
          "expr": "sum(increase(catering_order_ready_count_total[24h]))",
          "refId": "A"
        }
      ]
    },
    {
      "type": "stat",
      "title": "Successful pickups (24h)",
      "datasource": {
        "type": "prometheus",
        "uid": "VictoriaMetrics"
      },
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 6,
        "y": 0
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "noValue": "0"
        }
      },
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        }
      },
      "targets": [
        {
          "expr": "sum(increase(catering_order_pickup_verified_count_total{outcome=\"success\"}[24h]))",
          "refId": "A"
        }
      ]
    },
    {
      "type": "stat",
      "title": "Pickup failure ratio (1h)",
      "datasource": {
        "type": "prometheus",
        "uid": "VictoriaMetrics"
      },
      "description": "Failed verify attempts / total attempts. >30% = broken scanner or bad TOTP code distribution somewhere.",
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 12,
        "y": 0
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "decimals": 1,
          "noValue": "\u2014",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green"
              },
              {
                "color": "yellow",
                "value": 0.1
              },
              {
                "color": "red",
                "value": 0.3
              }
            ]
          }
        }
      },
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        }
      },
      "targets": [
        {
          "expr": "sum(increase(catering_order_pickup_verified_count_total{outcome!=\"success\"}[1h])) / clamp_min(sum(increase(catering_order_pickup_verified_count_total[1h])), 1)",
          "refId": "A"
        }
      ]
    },
    {
      "type": "stat",
      "title": "No-show (24h)",
      "datasource": {
        "type": "prometheus",
        "uid": "VictoriaMetrics"
      },
      "description": "READY orders that aged out without pickup. Waste indicator + signal for vendor over-supply.",
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 18,
        "y": 0
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "noValue": "0",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green"
              },
              {
                "color": "yellow",
                "value": 5
              },
              {
                "color": "red",
                "value": 20
              }
            ]
          }
        }
      },
      "options": {
        "colorMode": "background",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        }
      },
      "targets": [
        {
          "expr": "sum(increase(catering_order_no_show_count_total[24h]))",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Pickup attempts by outcome \u2014 broken scanner / typo / state mismatch all visible here",
      "datasource": {
        "type": "prometheus",
        "uid": "VictoriaMetrics"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 4
      },
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "custom": {
            "drawStyle": "bars",
            "fillOpacity": 80,
            "showPoints": "never",
            "stacking": {
              "mode": "normal"
            }
          }
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "success"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "mode": "fixed",
                  "fixedColor": "green"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "invalid_code"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "mode": "fixed",
                  "fixedColor": "red"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "wrong_state"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "mode": "fixed",
                  "fixedColor": "orange"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "order_lookup_failed"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "mode": "fixed",
                  "fixedColor": "purple"
                }
              }
            ]
          }
        ]
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": [
            "sum"
          ]
        }
      },
      "targets": [
        {
          "expr": "sum by (outcome) (rate(catering_order_pickup_verified_count_total[1m]))",
          "legendFormat": "{{outcome}}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Pickups per plant (success only)",
      "datasource": {
        "type": "prometheus",
        "uid": "VictoriaMetrics"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 4
      },
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 10,
            "showPoints": "never"
          },
          "noValue": "\u2014"
        }
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": [
            "sum"
          ]
        }
      },
      "targets": [
        {
          "expr": "sum by (plant_id) (rate(catering_order_pickup_verified_count_total{outcome=\"success\"}[1m]))",
          "legendFormat": "{{plant_id}}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "table",
      "title": "Failure attribution (top vendor \u00d7 outcome, 5m)",
      "datasource": {
        "type": "prometheus",
        "uid": "VictoriaMetrics"
      },
      "description": "Concentrates by (vendor, outcome) so a single vendor's failing pickup flow jumps out. Outcomes: forbidden (employee scanned someone else's QR), wrong_state (already picked up or not yet ready), concurrent_modification (deadlock retry path). Cross-check with /api/employee/orders/{id}/pickup HTTP latency below.",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 12
      },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "align": "left"
          }
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "Value"
            },
            "properties": [
              {
                "id": "unit",
                "value": "ops"
              },
              {
                "id": "displayName",
                "value": "rate"
              },
              {
                "id": "decimals",
                "value": 2
              },
              {
                "id": "custom.cellOptions",
                "value": {
                  "type": "color-background"
                }
              },
              {
                "id": "thresholds",
                "value": {
                  "mode": "absolute",
                  "steps": [
                    {
                      "color": "green"
                    },
                    {
                      "color": "yellow",
                      "value": 0.5
                    },
                    {
                      "color": "red",
                      "value": 5
                    }
                  ]
                }
              }
            ]
          }
        ]
      },
      "options": {
        "showHeader": true,
        "sortBy": [
          {
            "displayName": "rate",
            "desc": true
          }
        ]
      },
      "targets": [
        {
          "expr": "topk(10, sum by (vendor_id, plant_id, outcome) (rate(catering_order_pickup_verified_count_total{outcome!=\"success\"}[5m])))",
          "instant": true,
          "format": "table",
          "refId": "A"
        }
      ],
      "transformations": [
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Time": true
            },
            "indexByName": {
              "vendor_id": 0,
              "plant_id": 1,
              "outcome": 2,
              "Value": 3
            }
          }
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "HTTP /employee/orders/{id}/pickup latency (p50/p95/p99)",
      "datasource": {
        "type": "prometheus",
        "uid": "VictoriaMetrics"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 12
      },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 5,
            "showPoints": "never"
          }
        }
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": [
            "mean",
            "max"
          ]
        }
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum by (le) (rate(http_server_request_duration_seconds_bucket{http_route=\"/api/employee/orders/{id}/pickup\"}[5m])))",
          "legendFormat": "p50",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum by (le) (rate(http_server_request_duration_seconds_bucket{http_route=\"/api/employee/orders/{id}/pickup\"}[5m])))",
          "legendFormat": "p95",
          "refId": "B"
        },
        {
          "expr": "histogram_quantile(0.99, sum by (le) (rate(http_server_request_duration_seconds_bucket{http_route=\"/api/employee/orders/{id}/pickup\"}[5m])))",
          "legendFormat": "p99",
          "refId": "C"
        }
      ]
    }
  ],
  "refresh": "30s",
  "schemaVersion": 39,
  "tags": [
    "domain",
    "pickup"
  ],
  "templating": {
    "list": []
  },
  "time": {
    "from": "now-3h",
    "to": "now"
  },
  "timezone": "browser",
  "title": "Pickup Floor",
  "uid": "pickup-floor",
  "version": 2
}