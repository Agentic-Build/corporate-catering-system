{
  "__inputs": [
    {
      "name": "DS_VICTORIA_METRICS",
      "label": "VictoriaMetrics",
      "description": "VictoriaMetrics (Prometheus-compatible) datasource backing tbite observability.",
      "type": "datasource",
      "pluginId": "prometheus",
      "pluginName": "Prometheus"
    }
  ],
  "__elements": {},
  "__requires": [
    { "type": "grafana", "id": "grafana", "name": "Grafana", "version": "10.0.0" },
    { "type": "datasource", "id": "prometheus", "name": "Prometheus", "version": "1.0.0" },
    { "type": "panel", "id": "timeseries", "name": "Time series", "version": "" },
    { "type": "panel", "id": "stat", "name": "Stat", "version": "" }
  ],
  "annotations": { "list": [] },
  "description": "Read-model cache health (architecture baseline issue #57). Hit/miss for menu/home/recommendation read models, recomputation lag, TTL distribution.",
  "editable": false,
  "graphTooltip": 1,
  "id": null,
  "panels": [
    {
      "type": "row",
      "title": "Cache hit ratio",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "collapsed": false
    },
    {
      "type": "timeseries",
      "title": "Hit ratio by model",
      "datasource": { "type": "prometheus", "uid": "victoria-metrics" },
      "gridPos": { "h": 8, "w": 16, "x": 0, "y": 1 },
      "id": 1,
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "custom": { "drawStyle": "line", "fillOpacity": 10, "showPoints": "never" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red" },
              { "color": "yellow", "value": 0.8 },
              { "color": "green", "value": 0.95 }
            ]
          }
        }
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean"] }
      },
      "targets": [
        {
          "expr": "sum by (model) (rate(tbite_readmodel_cache_hits_total[5m])) / (sum by (model) (rate(tbite_readmodel_cache_hits_total[5m])) + sum by (model) (rate(tbite_readmodel_cache_misses_total[5m])))",
          "legendFormat": "{{model}}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "stat",
      "title": "Overall hit ratio (5m)",
      "datasource": { "type": "prometheus", "uid": "victoria-metrics" },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 1 },
      "id": 2,
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red" },
              { "color": "yellow", "value": 0.8 },
              { "color": "green", "value": 0.95 }
            ]
          }
        }
      },
      "options": {
        "colorMode": "background",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      },
      "targets": [
        {
          "expr": "sum(rate(tbite_readmodel_cache_hits_total[5m])) / (sum(rate(tbite_readmodel_cache_hits_total[5m])) + sum(rate(tbite_readmodel_cache_misses_total[5m])))",
          "refId": "A"
        }
      ]
    },
    {
      "type": "row",
      "title": "Hit/miss volume",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 9 },
      "collapsed": false
    },
    {
      "type": "timeseries",
      "title": "Hits + misses per second",
      "datasource": { "type": "prometheus", "uid": "victoria-metrics" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 10 },
      "id": 3,
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "custom": { "drawStyle": "line", "fillOpacity": 10, "showPoints": "never" }
        }
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean"] }
      },
      "targets": [
        {
          "expr": "sum by (model) (rate(tbite_readmodel_cache_hits_total[1m]))",
          "legendFormat": "hit {{model}}",
          "refId": "A"
        },
        {
          "expr": "sum by (model) (rate(tbite_readmodel_cache_misses_total[1m]))",
          "legendFormat": "miss {{model}}",
          "refId": "B"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Read-model recomputation lag",
      "datasource": { "type": "prometheus", "uid": "victoria-metrics" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 10 },
      "id": 4,
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": { "drawStyle": "line", "fillOpacity": 10, "showPoints": "never" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green" },
              { "color": "yellow", "value": 5 },
              { "color": "red", "value": 30 }
            ]
          }
        }
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["max", "mean"] }
      },
      "targets": [
        {
          "expr": "tbite_readmodel_recompute_lag_seconds",
          "legendFormat": "{{model}}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Cached entry TTL distribution (p50/p95/p99)",
      "datasource": { "type": "prometheus", "uid": "victoria-metrics" },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 18 },
      "id": 5,
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": { "drawStyle": "line", "fillOpacity": 10, "showPoints": "never" }
        }
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean"] }
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.5, sum by (le, model) (rate(tbite_readmodel_ttl_seconds_bucket[5m])))",
          "legendFormat": "p50 {{model}}",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum by (le, model) (rate(tbite_readmodel_ttl_seconds_bucket[5m])))",
          "legendFormat": "p95 {{model}}",
          "refId": "B"
        },
        {
          "expr": "histogram_quantile(0.99, sum by (le, model) (rate(tbite_readmodel_ttl_seconds_bucket[5m])))",
          "legendFormat": "p99 {{model}}",
          "refId": "C"
        }
      ]
    }
  ],
  "refresh": "30s",
  "schemaVersion": 39,
  "tags": ["tbite", "architecture-baseline-47"],
  "templating": { "list": [] },
  "time": { "from": "now-1h", "to": "now" },
  "timezone": "browser",
  "title": "Read Models — Cache + Recompute",
  "uid": "read-models",
  "version": 1
}
