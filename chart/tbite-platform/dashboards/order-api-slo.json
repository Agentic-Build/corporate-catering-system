{
  "annotations": {
    "list": []
  },
  "description": "Order API SLO \u2014 corresponds to ops/observability/slo/hard-slo-policy.yaml. Availability + p95/p99 latency + error budget burn.",
  "editable": false,
  "graphTooltip": 1,
  "id": null,
  "panels": [
    {
      "type": "stat",
      "title": "Availability (28d)",
      "datasource": {
        "type": "prometheus",
        "uid": "VictoriaMetrics"
      },
      "gridPos": {
        "h": 5,
        "w": 6,
        "x": 0,
        "y": 0
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "decimals": 3,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red"
              },
              {
                "color": "yellow",
                "value": 99.85
              },
              {
                "color": "green",
                "value": 99.9
              }
            ]
          }
        }
      },
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        }
      },
      "targets": [
        {
          "expr": "100 * (sum(rate(http_server_request_duration_seconds_count{http_route=\"/api/employee/orders\",http_request_method=\"POST\",http_response_status_code!~\"5..\",deployment_environment=~\"$env\"}[28d])) / sum(rate(http_server_request_duration_seconds_count{http_route=\"/api/employee/orders\",http_request_method=\"POST\",deployment_environment=~\"$env\"}[28d])))",
          "refId": "A"
        }
      ]
    },
    {
      "type": "stat",
      "title": "Target",
      "datasource": {
        "type": "prometheus",
        "uid": "VictoriaMetrics"
      },
      "gridPos": {
        "h": 5,
        "w": 3,
        "x": 6,
        "y": 0
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "decimals": 2
        }
      },
      "options": {
        "colorMode": "none",
        "graphMode": "none",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        }
      },
      "targets": [
        {
          "expr": "vector(99.90)",
          "refId": "A"
        }
      ]
    },
    {
      "type": "gauge",
      "title": "Error budget remaining (28d)",
      "datasource": {
        "type": "prometheus",
        "uid": "VictoriaMetrics"
      },
      "gridPos": {
        "h": 5,
        "w": 6,
        "x": 9,
        "y": 0
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red"
              },
              {
                "color": "yellow",
                "value": 20
              },
              {
                "color": "green",
                "value": 50
              }
            ]
          }
        }
      },
      "options": {
        "showThresholdMarkers": true,
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        }
      },
      "targets": [
        {
          "expr": "clamp_min(100 * (1 - ((1 - (sum(rate(http_server_request_duration_seconds_count{http_route=\"/api/employee/orders\",http_request_method=\"POST\",http_response_status_code!~\"5..\",deployment_environment=~\"$env\"}[28d])) / sum(rate(http_server_request_duration_seconds_count{http_route=\"/api/employee/orders\",http_request_method=\"POST\",deployment_environment=~\"$env\"}[28d])))) / 0.001)), 0)",
          "refId": "A"
        }
      ]
    },
    {
      "type": "stat",
      "title": "Burn rate (1h)",
      "datasource": {
        "type": "prometheus",
        "uid": "VictoriaMetrics"
      },
      "gridPos": {
        "h": 5,
        "w": 9,
        "x": 15,
        "y": 0
      },
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "decimals": 2,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green"
              },
              {
                "color": "yellow",
                "value": 2
              },
              {
                "color": "red",
                "value": 6
              }
            ]
          }
        }
      },
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        }
      },
      "targets": [
        {
          "expr": "(1 - (sum(rate(http_server_request_duration_seconds_count{http_route=\"/api/employee/orders\",http_request_method=\"POST\",http_response_status_code!~\"5..\",deployment_environment=~\"$env\"}[1h])) / sum(rate(http_server_request_duration_seconds_count{http_route=\"/api/employee/orders\",http_request_method=\"POST\",deployment_environment=~\"$env\"}[1h])))) / 0.001",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "createEmployeeOrder \u2014 request rate by status",
      "datasource": {
        "type": "prometheus",
        "uid": "VictoriaMetrics"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 5
      },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 20,
            "showPoints": "never",
            "stacking": {
              "mode": "normal"
            }
          }
        }
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        }
      },
      "targets": [
        {
          "expr": "sum by (http_response_status_code) (rate(http_server_request_duration_seconds_count{http_route=\"/api/employee/orders\",http_request_method=\"POST\",deployment_environment=~\"$env\"}[1m]))",
          "legendFormat": "{{http_response_status_code}}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "createEmployeeOrder \u2014 latency quantiles",
      "datasource": {
        "type": "prometheus",
        "uid": "VictoriaMetrics"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 5
      },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 5,
            "showPoints": "never"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green"
              },
              {
                "color": "yellow",
                "value": 0.35
              },
              {
                "color": "red",
                "value": 0.5
              }
            ]
          }
        }
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": [
            "mean",
            "max"
          ]
        }
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum by (le) (rate(http_server_request_duration_seconds_bucket{http_route=\"/api/employee/orders\",http_request_method=\"POST\",deployment_environment=~\"$env\"}[5m])))",
          "legendFormat": "p50",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum by (le) (rate(http_server_request_duration_seconds_bucket{http_route=\"/api/employee/orders\",http_request_method=\"POST\",deployment_environment=~\"$env\"}[5m])))",
          "legendFormat": "p95 (SLO 350ms)",
          "refId": "B"
        },
        {
          "expr": "histogram_quantile(0.99, sum by (le) (rate(http_server_request_duration_seconds_bucket{http_route=\"/api/employee/orders\",http_request_method=\"POST\",deployment_environment=~\"$env\"}[5m])))",
          "legendFormat": "p99 (SLO 500ms)",
          "refId": "C"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Multi-window burn rates",
      "datasource": {
        "type": "prometheus",
        "uid": "VictoriaMetrics"
      },
      "gridPos": {
        "h": 8,
        "w": 24,
        "x": 0,
        "y": 13
      },
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 0,
            "lineWidth": 2
          }
        }
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": [
            "mean",
            "max"
          ]
        }
      },
      "targets": [
        {
          "expr": "(1 - (sum(rate(http_server_request_duration_seconds_count{http_route=\"/api/employee/orders\",http_request_method=\"POST\",http_response_status_code!~\"5..\",deployment_environment=~\"$env\"}[5m])) / sum(rate(http_server_request_duration_seconds_count{http_route=\"/api/employee/orders\",http_request_method=\"POST\",deployment_environment=~\"$env\"}[5m])))) / 0.001",
          "legendFormat": "5m burn",
          "refId": "A"
        },
        {
          "expr": "(1 - (sum(rate(http_server_request_duration_seconds_count{http_route=\"/api/employee/orders\",http_request_method=\"POST\",http_response_status_code!~\"5..\",deployment_environment=~\"$env\"}[1h])) / sum(rate(http_server_request_duration_seconds_count{http_route=\"/api/employee/orders\",http_request_method=\"POST\",deployment_environment=~\"$env\"}[1h])))) / 0.001",
          "legendFormat": "1h burn",
          "refId": "B"
        },
        {
          "expr": "(1 - (sum(rate(http_server_request_duration_seconds_count{http_route=\"/api/employee/orders\",http_request_method=\"POST\",http_response_status_code!~\"5..\",deployment_environment=~\"$env\"}[6h])) / sum(rate(http_server_request_duration_seconds_count{http_route=\"/api/employee/orders\",http_request_method=\"POST\",deployment_environment=~\"$env\"}[6h])))) / 0.001",
          "legendFormat": "6h burn",
          "refId": "C"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Place() service-method latency by outcome",
      "datasource": {
        "type": "prometheus",
        "uid": "VictoriaMetrics"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 21
      },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 10,
            "showPoints": "never"
          }
        }
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": [
            "mean"
          ]
        }
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (le, outcome) (rate(catering_order_place_duration_seconds_bucket{deployment_environment=~\"$env\"}[5m])))",
          "legendFormat": "p95 {{outcome}}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Place() outcome rate",
      "datasource": {
        "type": "prometheus",
        "uid": "VictoriaMetrics"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 21
      },
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 20,
            "showPoints": "never",
            "stacking": {
              "mode": "normal"
            }
          }
        }
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        }
      },
      "targets": [
        {
          "expr": "sum by (outcome) (rate(catering_order_placed_count_total{deployment_environment=~\"$env\"}[1m]))",
          "legendFormat": "{{outcome}}",
          "refId": "A"
        }
      ]
    }
  ],
  "refresh": "30s",
  "schemaVersion": 39,
  "tags": [
    "slo",
    "order"
  ],
  "templating": {
    "list": [
      {
        "name": "env",
        "type": "custom",
        "label": "Environment",
        "options": [
          {
            "text": "all",
            "value": ".*",
            "selected": true
          },
          {
            "text": "development",
            "value": "development"
          },
          {
            "text": "production",
            "value": "production"
          }
        ],
        "current": {
          "text": "all",
          "value": ".*"
        }
      }
    ]
  },
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "timezone": "browser",
  "title": "Order API \u2014 SLO",
  "uid": "order-api-slo",
  "version": 1,
  "links": [
    {
      "title": "System Status",
      "type": "link",
      "url": "/d/status",
      "icon": "external link",
      "targetBlank": false
    },
    {
      "title": "Service Health",
      "type": "link",
