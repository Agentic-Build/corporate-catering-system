{
  "annotations": {
    "list": []
  },
  "description": "Authentication health \u2014 Authentik (OIDC) + Hydra (OAuth + RFC 7591 DCR). HTTP routes proxied under /auth/* and /oauth2/*.",
  "editable": false,
  "graphTooltip": 1,
  "id": null,
  "panels": [
    {
      "type": "stat",
      "title": "Login attempts (1h)",
      "datasource": {
        "type": "prometheus",
        "uid": "VictoriaMetrics"
      },
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 0,
        "y": 0
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "noValue": "0"
        }
      },
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        }
      },
      "targets": [
        {
          "expr": "sum(increase(http_server_request_duration_seconds_count{http_route=~\"/auth/.*|/oauth/.*|/oauth2/.*|/\\.well-known/.*|/userinfo\"}[1h]))",
          "refId": "A"
        }
      ]
    },
    {
      "type": "stat",
      "title": "Login failures (1h)",
      "datasource": {
        "type": "prometheus",
        "uid": "VictoriaMetrics"
      },
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 6,
        "y": 0
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green"
              },
              {
                "color": "yellow",
                "value": 5
              },
              {
                "color": "red",
                "value": 25
              }
            ]
          },
          "noValue": "0"
        }
      },
      "options": {
        "colorMode": "background",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        }
      },
      "targets": [
        {
          "expr": "sum(increase(http_server_request_duration_seconds_count{http_route=~\"/auth/.*|/oauth/.*|/oauth2/.*|/\\.well-known/.*|/userinfo\",http_response_status_code=~\"4(01|03)\"}[1h]))",
          "refId": "A"
        }
      ]
    },
    {
      "type": "stat",
      "title": "DCR registrations (1h)",
      "datasource": {
        "type": "prometheus",
        "uid": "VictoriaMetrics"
      },
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 12,
        "y": 0
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "noValue": "0"
        }
      },
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        }
      },
      "targets": [
        {
          "expr": "sum(increase(http_server_request_duration_seconds_count{http_route=\"/oauth2/register\",http_request_method=\"POST\"}[1h]))",
          "refId": "A"
        }
      ]
    },
    {
      "type": "stat",
      "title": "Token exchanges (1h)",
      "datasource": {
        "type": "prometheus",
        "uid": "VictoriaMetrics"
      },
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 18,
        "y": 0
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "noValue": "0"
        }
      },
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        }
      },
      "targets": [
        {
          "expr": "sum(increase(http_server_request_duration_seconds_count{http_route=\"/oauth2/token\"}[1h]))",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "/auth/* and /oauth2/* status codes",
      "datasource": {
        "type": "prometheus",
        "uid": "VictoriaMetrics"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 4
      },
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 10,
            "showPoints": "never"
          }
        }
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": [
            "sum"
          ]
        }
      },
      "targets": [
        {
          "expr": "sum by (http_route, http_response_status_code) (rate(http_server_request_duration_seconds_count{http_route=~\"/auth/.*|/oauth/.*|/oauth2/.*|/\\.well-known/.*|/userinfo\"}[5m]))",
          "legendFormat": "{{http_route}} {{http_response_status_code}}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "OIDC callback latency (p95)",
      "datasource": {
        "type": "prometheus",
        "uid": "VictoriaMetrics"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 4
      },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 5,
            "showPoints": "never"
          }
        }
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": [
            "mean",
            "max"
          ]
        }
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (le, http_route) (rate(http_server_request_duration_seconds_bucket{http_route=~\"/auth/.*|/oauth/.*|/oauth2/.*|/\\.well-known/.*|/userinfo\"}[5m])))",
          "legendFormat": "{{http_route}}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "table",
      "title": "Recent auth 4xx by route (1h)",
      "datasource": {
        "type": "prometheus",
        "uid": "VictoriaMetrics"
      },
      "gridPos": {
        "h": 8,
        "w": 24,
        "x": 0,
        "y": 12
      },
      "options": {
        "showHeader": true
      },
      "targets": [
        {
          "expr": "topk(20, sum by (http_route, http_response_status_code) (increase(http_server_request_duration_seconds_count{http_route=~\"/auth/.*|/oauth/.*|/oauth2/.*|/\\.well-known/.*|/userinfo\",http_response_status_code=~\"4..\"}[1h])))",
          "instant": true,
          "format": "table",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "noValue": "no recent 4xx \u2713"
        }
      }
    }
  ],
  "refresh": "1m",
  "schemaVersion": 39,
  "tags": [
    "platform",
    "auth"
  ],
  "templating": {
    "list": []
  },
  "time": {
    "from": "now-6h",
    "to": "now"
  },
  "timezone": "browser",
  "title": "Auth \u2014 Authentik + Hydra",
  "uid": "auth-health",
  "version": 1,
  "links": [
    {
      "title": "\u2605 System Status",
      "type": "link",
      "url": "/d/status",
      "icon": "external link",
      "targetBlank": false
    },
    {
      "title": "\u25c6 Service Health",
      "type": "link",
      "url": "/d/oncall-overview",
      "icon": "external link",
      "targetBlank": false
    }
  ]
}