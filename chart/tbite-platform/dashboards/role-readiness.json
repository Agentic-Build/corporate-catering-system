{
  "__inputs": [
    {
      "name": "DS_VICTORIA_METRICS",
      "label": "VictoriaMetrics",
      "description": "VictoriaMetrics (Prometheus-compatible) datasource backing tbite observability.",
      "type": "datasource",
      "pluginId": "prometheus",
      "pluginName": "Prometheus"
    }
  ],
  "__elements": {},
  "__requires": [
    { "type": "grafana", "id": "grafana", "name": "Grafana", "version": "10.0.0" },
    { "type": "datasource", "id": "prometheus", "name": "Prometheus", "version": "1.0.0" },
    { "type": "panel", "id": "timeseries", "name": "Time series", "version": "" },
    { "type": "panel", "id": "stat", "name": "Stat", "version": "" },
    { "type": "panel", "id": "table", "name": "Table", "version": "" }
  ],
  "annotations": { "list": [] },
  "description": "Per-role /readyz health (architecture baseline issue #62). Probe success rate, restart count by role, ready-state flapping.",
  "editable": false,
  "graphTooltip": 1,
  "id": null,
  "panels": [
    {
      "type": "row",
      "title": "Readiness",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "collapsed": false
    },
    {
      "type": "timeseries",
      "title": "Ready pods per role",
      "datasource": { "type": "prometheus", "uid": "victoria-metrics" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 1 },
      "id": 1,
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": { "drawStyle": "line", "fillOpacity": 10, "showPoints": "never", "stacking": { "mode": "normal" } }
        }
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["last"] }
      },
      "targets": [
        {
          "expr": "sum by (label_app_kubernetes_io_component) (kube_pod_status_ready{namespace=\"tbite\",condition=\"true\"} * on(pod, namespace) group_left(label_app_kubernetes_io_component) kube_pod_labels{namespace=\"tbite\"})",
          "legendFormat": "{{label_app_kubernetes_io_component}}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "/readyz HTTP success rate per role",
      "datasource": { "type": "prometheus", "uid": "victoria-metrics" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 1 },
      "id": 2,
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "custom": { "drawStyle": "line", "fillOpacity": 10, "showPoints": "never" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red" },
              { "color": "yellow", "value": 0.95 },
              { "color": "green", "value": 0.99 }
            ]
          }
        }
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean"] }
      },
      "targets": [
        {
          "expr": "sum by (role) (rate(http_server_request_duration_seconds_count{http_route=\"/readyz\",http_response_status_code=\"200\"}[5m])) / sum by (role) (rate(http_server_request_duration_seconds_count{http_route=\"/readyz\"}[5m]))",
          "legendFormat": "{{role}}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "row",
      "title": "Stability",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 9 },
      "collapsed": false
    },
    {
      "type": "timeseries",
      "title": "Ready-state flap count (10m increase, per pod)",
      "datasource": { "type": "prometheus", "uid": "victoria-metrics" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 10 },
      "id": 3,
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": { "drawStyle": "line", "fillOpacity": 10, "showPoints": "never" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green" },
              { "color": "yellow", "value": 3 },
              { "color": "red", "value": 5 }
            ]
          }
        }
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["max"] }
      },
      "targets": [
        {
          "expr": "increase(kube_pod_ready_changed_total{namespace=\"tbite\"}[10m])",
          "legendFormat": "{{pod}}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Container restarts per role (1h)",
      "datasource": { "type": "prometheus", "uid": "victoria-metrics" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 10 },
      "id": 4,
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": { "drawStyle": "line", "fillOpacity": 10, "showPoints": "never" }
        }
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["max"] }
      },
      "targets": [
        {
          "expr": "sum by (container) (increase(kube_pod_container_status_restarts_total{namespace=\"tbite\"}[1h]))",
          "legendFormat": "{{container}}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "table",
      "title": "Currently not-ready pods",
      "datasource": { "type": "prometheus", "uid": "victoria-metrics" },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 18 },
      "id": 5,
      "options": {
        "showHeader": true
      },
      "targets": [
        {
          "expr": "kube_pod_status_ready{namespace=\"tbite\",condition=\"true\"} == 0",
          "format": "table",
          "instant": true,
          "refId": "A"
        }
      ]
    }
  ],
  "refresh": "30s",
  "schemaVersion": 39,
  "tags": ["tbite", "architecture-baseline-47"],
  "templating": { "list": [] },
  "time": { "from": "now-1h", "to": "now" },
  "timezone": "browser",
  "title": "Role Readiness — /readyz + Restarts",
  "uid": "role-readiness",
  "version": 1
}
