{
  "annotations": {
    "list": []
  },
  "description": "Supply / vendor capacity health. Adjustments + per-vendor remaining capacity sourced from postgres-exporter custom queries (ops/observability/postgres-exporter/queries.yaml).",
  "editable": false,
  "graphTooltip": 1,
  "id": null,
  "panels": [
    {
      "type": "stat",
      "title": "Capacity adjustments (24h)",
      "datasource": {
        "type": "prometheus",
        "uid": "VictoriaMetrics"
      },
      "gridPos": {
        "h": 4,
        "w": 12,
        "x": 0,
        "y": 0
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        }
      },
      "options": {
        "orientation": "horizontal",
        "textMode": "value_and_name",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "value"
      },
      "targets": [
        {
          "expr": "sum by (direction) (increase(catering_supply_adjusted_count_total[24h]))",
          "legendFormat": "{{direction}}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "stat",
      "title": "Quota exhausted (24h)",
      "datasource": {
        "type": "prometheus",
        "uid": "VictoriaMetrics"
      },
      "gridPos": {
        "h": 4,
        "w": 12,
        "x": 12,
        "y": 0
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green"
              },
              {
                "color": "yellow",
                "value": 10
              },
              {
                "color": "red",
                "value": 50
              }
            ]
          }
        }
      },
      "options": {
        "colorMode": "background",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        }
      },
      "targets": [
        {
          "expr": "sum(increase(catering_quota_exhausted_count_total[24h]))",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Capacity adjustments by vendor (direction)",
      "datasource": {
        "type": "prometheus",
        "uid": "VictoriaMetrics"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 4
      },
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 10,
            "showPoints": "never"
          }
        }
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": [
            "sum"
          ]
        }
      },
      "targets": [
        {
          "expr": "sum by (vendor_id, direction) (rate(catering_supply_adjusted_count_total[5m]))",
          "legendFormat": "{{vendor_id}} ({{direction}})",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Adjustment magnitude (p95 absolute delta)",
      "datasource": {
        "type": "prometheus",
        "uid": "VictoriaMetrics"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 4
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 10,
            "showPoints": "never"
          }
        }
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": [
            "mean",
            "max"
          ]
        }
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (le, direction) (rate(catering_supply_adjusted_qty_bucket[5m])))",
          "legendFormat": "p95 {{direction}}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Quota exhausted by vendor \u00d7 menu item",
      "datasource": {
        "type": "prometheus",
        "uid": "VictoriaMetrics"
      },
      "gridPos": {
        "h": 8,
        "w": 24,
        "x": 0,
        "y": 12
      },
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "custom": {
            "drawStyle": "bars",
            "fillOpacity": 60,
            "showPoints": "never"
          }
        }
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": [
            "sum"
          ]
        }
      },
      "targets": [
        {
          "expr": "topk(10, sum by (vendor_id, menu_item_id) (rate(catering_quota_exhausted_count_total[5m])) + on (menu_item_id) group_left(item_name, vendor_name) (0 * max by (menu_item_id, item_name, vendor_name) (tbite_item_supply_capacity{vendor_name!=\"\"})))",
          "legendFormat": "{{item_name}} ({{vendor_name}})",
          "refId": "A"
        }
      ]
    },
    {
      "type": "stat",
      "title": "Today \u2014 total remaining vs capacity",
      "datasource": {
        "type": "prometheus",
        "uid": "VictoriaMetrics"
      },
      "gridPos": {
        "h": 5,
        "w": 12,
        "x": 0,
        "y": 20
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "noValue": "0"
        }
      },
      "options": {
        "orientation": "horizontal",
        "textMode": "value_and_name",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "value"
      },
      "targets": [
        {
          "expr": "sum(tbite_supply_remain{supply_date=~\".+\"} and on(supply_date) (vector(0)+0))",
          "legendFormat": "remain (any date)",
          "refId": "X",
          "hide": true
        },
        {
          "expr": "sum(tbite_supply_remain) by (supply_date)",
          "legendFormat": "remain {{supply_date}}",
          "refId": "A"
        },
        {
          "expr": "sum(tbite_supply_capacity) by (supply_date)",
          "legendFormat": "capacity {{supply_date}}",
          "refId": "B"
        }
      ]
    },
    {
      "type": "gauge",
      "title": "Today \u2014 utilization (1 - remain/capacity)",
      "datasource": {
        "type": "prometheus",
        "uid": "VictoriaMetrics"
      },
      "gridPos": {
        "h": 5,
        "w": 12,
        "x": 12,
        "y": 20
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "decimals": 2,
          "noValue": "no data",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green"
              },
              {
                "color": "yellow",
                "value": 0.8
              },
              {
                "color": "red",
                "value": 0.95
              }
            ]
          }
        }
      },
      "options": {
        "showThresholdMarkers": true,
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        }
      },
      "targets": [
        {
          "expr": "1 - clamp_min(sum(tbite_supply_remain), 0) / clamp_min(sum(tbite_supply_capacity), 1)",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Remaining capacity by vendor (next 7 days)",
      "datasource": {
        "type": "prometheus",
        "uid": "VictoriaMetrics"
      },
      "gridPos": {
        "h": 8,
        "w": 24,
        "x": 0,
        "y": 25
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 10,
            "showPoints": "never"
          }
        }
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": [
            "min",
            "mean",
            "last"
          ]
        }
      },
      "targets": [
        {
          "expr": "sum by (vendor_id) (tbite_supply_remain)",
          "legendFormat": "{{vendor_id}}",
          "refId": "A"
        }
      ]
    }
  ],
  "refresh": "1m",
  "schemaVersion": 39,
  "tags": [
    "domain",
    "supply"
  ],
  "templating": {
    "list": []
  },
  "time": {
    "from": "now-6h",
    "to": "now"
  },
  "timezone": "browser",
  "title": "Supply Health",
  "uid": "supply-health",
  "version": 1,
  "links": [
    {
      "title": "\u2605 System Status",
      "type": "link",
      "url": "/d/status",
      "icon": "external link",
      "targetBlank": false
    },
    {
      "title": "\u25c6 Service Health",
      "type": "link",
      "url": "/d/oncall-overview",
      "icon": "external link",
      "targetBlank": false
    }
  ]
}