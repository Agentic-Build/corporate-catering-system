{
  "annotations": {
    "list": []
  },
  "description": "Layer 0 \u2014 single-page system status. 30s to know what's wrong and where to drill. Click any panel to jump to detail dashboards.",
  "editable": false,
  "graphTooltip": 1,
  "id": null,
  "links": [
    {
      "title": "Service Health (detailed)",
      "type": "dashboards",
      "tags": [
        "overview"
      ],
      "asDropdown": false,
      "icon": "dashboard",
      "includeVars": true,
      "keepTime": true,
      "targetBlank": false
    },
    {
      "title": "Detail dashboards",
      "type": "dashboards",
      "tags": [
        "domain",
        "platform",
        "infra"
      ],
      "asDropdown": true,
      "icon": "external link",
      "includeVars": true,
      "keepTime": true
    }
  ],
  "panels": [
    {
      "type": "row",
      "title": "Headline",
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 0
      },
      "collapsed": false
    },
    {
      "type": "stat",
      "title": "Active alerts",
      "datasource": {
        "type": "prometheus",
        "uid": "VictoriaMetrics"
      },
      "gridPos": {
        "h": 5,
        "w": 6,
        "x": 0,
        "y": 1
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "noValue": "0",
          "mappings": [
            {
              "options": {
                "0": {
                  "color": "green",
                  "text": "ALL CLEAR"
                }
              },
              "type": "value"
            }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green"
              },
              {
                "color": "yellow",
                "value": 1
              },
              {
                "color": "red",
                "value": 2
              }
            ]
          }
        }
      },
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "textMode": "value"
      },
      "targets": [
        {
          "expr": "count(ALERTS{alertstate=\"firing\"}) or vector(0)",
          "refId": "A"
        }
      ],
      "links": [
        {
          "title": "vmalert UI",
          "url": "http://localhost:8880",
          "targetBlank": true
        }
      ]
    },
    {
      "type": "stat",
      "title": "Place-order success rate (5m)",
      "datasource": {
        "type": "prometheus",
        "uid": "VictoriaMetrics"
      },
      "gridPos": {
        "h": 5,
        "w": 6,
        "x": 6,
        "y": 1
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "decimals": 1,
          "min": 0,
          "max": 1,
          "noValue": "\u2014",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red"
              },
              {
                "color": "yellow",
                "value": 0.85
              },
              {
                "color": "green",
                "value": 0.95
              }
            ]
          }
        }
      },
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        }
      },
      "targets": [
        {
          "expr": "sum(rate(catering_order_placed_count_total{outcome=\"success\"}[5m])) / clamp_min(sum(rate(http_server_request_duration_seconds_count{http_route=\"/api/employee/orders\",http_request_method=\"POST\"}[5m])), 0.001)",
          "refId": "A"
        }
      ],
      "links": [
        {
          "title": "Order API SLO",
          "url": "/d/order-api-slo",
          "targetBlank": false
        }
      ]
    },
    {
      "type": "stat",
      "title": "Place-order p95 (5m)",
      "datasource": {
        "type": "prometheus",
        "uid": "VictoriaMetrics"
      },
      "gridPos": {
        "h": 5,
        "w": 6,
        "x": 12,
        "y": 1
      },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "decimals": 3,
          "noValue": "\u2014",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green"
              },
              {
                "color": "yellow",
                "value": 0.35
              },
              {
                "color": "red",
                "value": 0.5
              }
            ]
          }
        }
      },
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        }
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (le) (rate(catering_order_place_duration_seconds_bucket{outcome=\"success\"}[5m])))",
          "refId": "A"
        }
      ],
      "links": [
        {
          "title": "Order API SLO",
          "url": "/d/order-api-slo",
          "targetBlank": false
        }
      ]
    },
    {
      "type": "stat",
      "title": "5xx server errors (5m) \u2014 needs oncall",
      "datasource": {
        "type": "prometheus",
        "uid": "VictoriaMetrics"
      },
      "gridPos": {
        "h": 5,
        "w": 6,
        "x": 18,
        "y": 1
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "noValue": "0",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green"
              },
              {
                "color": "red",
                "value": 1
              }
            ]
          }
        }
      },
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "textMode": "value"
      },
      "targets": [
        {
          "expr": "sum(increase(http_server_request_duration_seconds_count{http_response_status_code=~\"5..\"}[5m])) or vector(0)",
          "refId": "A"
        }
      ],
      "links": [
        {
          "title": "Service Health",
          "url": "/d/oncall-overview",
          "targetBlank": false
        }
      ]
    },
    {
      "type": "row",
      "title": "Recent firing / pending alerts",
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 6
      },
      "collapsed": false
    },
    {
      "type": "table",
      "title": "Alerts (firing + pending)",
      "datasource": {
        "type": "prometheus",
        "uid": "VictoriaMetrics"
      },
      "gridPos": {
        "h": 6,
        "w": 12,
        "x": 0,
        "y": 7
      },
      "fieldConfig": {
        "defaults": {
          "noValue": "no firing alerts",
          "custom": {
            "align": "left"
          }
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "alertstate"
            },
            "properties": [
              {
                "id": "mappings",
                "value": [
                  {
                    "options": {
                      "firing": {
                        "color": "red",
                        "text": "\ud83d\udd25 FIRING"
                      }
                    },
                    "type": "value"
                  },
                  {
                    "options": {
                      "pending": {
                        "color": "yellow",
                        "text": "\u23f3 pending"
                      }
                    },
                    "type": "value"
                  }
                ]
              },
              {
                "id": "custom.cellOptions",
                "value": {
                  "type": "color-background"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "Value"
            },
            "properties": [
              {
                "id": "displayName",
                "value": "current value"
              },
              {
                "id": "custom.cellOptions",
                "value": {
                  "type": "color-text"
                }
              }
            ]
          }
        ]
      },
      "options": {
        "showHeader": true,
        "sortBy": [
          {
            "displayName": "alertstate",
            "desc": true
          }
        ]
      },
      "targets": [
        {
          "expr": "ALERTS{alertstate=~\"firing|pending\"}",
          "instant": true,
          "format": "table",
          "refId": "A"
        }
      ],
      "transformations": [
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Time": true,
              "__name__": true,
              "job": true,
              "instance": true
            },
            "indexByName": {
              "alertstate": 0,
              "alertname": 1,
              "severity": 2,
              "slo": 3,
              "Value": 4
            }
          }
        }
      ]
    },
    {
      "type": "stat",
      "title": "% place attempts blocked by quota (5m)",
      "datasource": {
        "type": "prometheus",
        "uid": "VictoriaMetrics"
      },
      "description": "Fraction of place-order attempts that were rejected with outcome=quota_exhausted, over the last 5 minutes. A low number is the healthy steady state (capacity is keeping up with demand). A sustained spike means supply is too tight for the load \u2014 either an item's capacity was set too low, or a flash crowd hit one vendor. Click through to Supply Health for the per-item / per-day breakdown that pinpoints which row needs adjusting. (Note: capacity=0 by itself is not a misconfig \u2014 vendors may legitimately mark an item not-offered for a given day.)",
      "gridPos": {
        "h": 6,
        "w": 12,
        "x": 12,
        "y": 7
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "yellow", "value": 0.05},
              {"color": "red", "value": 0.20}
            ]
          }
        }
      },
      "options": {
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "colorMode": "background",
        "graphMode": "area",
        "textMode": "auto",
        "justifyMode": "center"
      },
      "targets": [
        {
          "expr": "sum(rate(catering_quota_exhausted_count_total[5m])) / clamp_min(sum(rate(catering_order_placed_count_total[5m])), 1e-9)",
          "refId": "A"
        }
      ],
      "links": [
        {
          "title": "Supply Health (item-level detail)",
          "url": "/d/supply-health",
          "targetBlank": false
        }
      ]
    },
    {
      "type": "row",
      "title": "Service health cards",
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 13
      },
      "collapsed": false
    },
    {
      "type": "stat",
      "title": "\ud83d\udce6 Order API",
      "datasource": {
        "type": "prometheus",
        "uid": "VictoriaMetrics"
      },
      "gridPos": {
        "h": 5,
        "w": 6,
        "x": 0,
        "y": 14
      },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "decimals": 1,
          "noValue": "idle",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green"
              },
              {
                "color": "yellow",
                "value": 100
              }
            ]
          }
        }
      },
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "textMode": "value_and_name"
      },
      "targets": [
        {
          "expr": "sum(rate(http_server_request_duration_seconds_count{http_route=~\"/api/employee/orders.*\"}[1m]))",
          "legendFormat": "req/s",
          "refId": "A"
        },
        {
          "expr": "sum(rate(http_server_request_duration_seconds_count{http_route=~\"/api/employee/orders.*\",http_response_status_code=~\"5..\"}[1m]))",
          "legendFormat": "5xx/s",
          "refId": "B"
        }
      ],
      "links": [
        {
          "title": "Order Lifecycle",
          "url": "/d/order-lifecycle",
          "targetBlank": false
        }
      ]
    },
    {
      "type": "stat",
      "title": "\ud83c\udf71 Supply",
      "datasource": {
        "type": "prometheus",
        "uid": "VictoriaMetrics"
      },
      "gridPos": {
        "h": 5,
        "w": 6,
        "x": 6,
        "y": 14
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "decimals": 2,
          "min": 0,
          "max": 1,
          "noValue": "\u2014",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green"
              },
              {
                "color": "yellow",
                "value": 0.8
              },
              {
                "color": "red",
                "value": 0.95
              }
            ]
          }
        }
      },
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "textMode": "value_and_name"
      },
      "targets": [
        {
          "expr": "1 - clamp_min(sum(tbite_supply_remain), 0) / clamp_min(sum(tbite_supply_capacity), 1)",
          "legendFormat": "utilization",
          "refId": "A"
        }
      ],
      "links": [
        {
          "title": "Supply Health",
          "url": "/d/supply-health",
          "targetBlank": false
        }
      ]
    },
    {
      "type": "stat",
      "title": "\ud83d\udd01 Async Plane",
      "datasource": {
        "type": "prometheus",
        "uid": "VictoriaMetrics"
      },
      "gridPos": {
        "h": 5,
        "w": 6,
        "x": 12,
        "y": 14
      },
      "description": "Async-plane health: outbox queue (publisher), DLQ (terminal failures), and oldest unpublished event age. Thresholds are calibrated for both count-scale (events queued) AND time-scale (seconds since oldest publish): yellow ≥ 20, red ≥ 300 flags either >20 events queued OR >20s of un-flushed events — both indicate the broker pump is falling behind, just measured differently. Drill into Async Plane for per-stream / per-consumer breakdown.",
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "noValue": "0",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green"
              },
              {
                "color": "yellow",
                "value": 20
              },
              {
                "color": "red",
                "value": 300
              }
            ]
          }
        }
      },
      "options": {
        "colorMode": "value",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "textMode": "value_and_name"
      },
      "targets": [
        {
          "expr": "sum(tbite_dlq_pending) or vector(0)",
          "legendFormat": "DLQ pending",
          "refId": "A"
        },
        {
          "expr": "sum(tbite_outbox_pending) or vector(0)",
          "legendFormat": "outbox pending",
          "refId": "B"
        },
        {
          "expr": "max(tbite_outbox_oldest_seconds) or vector(0)",
          "legendFormat": "outbox oldest (s)",
          "refId": "C"
        }
      ],
      "links": [
        {
          "title": "Async Plane",
          "url": "/d/async-plane",
          "targetBlank": false
        }
      ]
    },
    {
      "type": "stat",
      "title": "\ud83d\udee0 Infra",
      "datasource": {
        "type": "prometheus",
        "uid": "VictoriaMetrics"
      },
      "gridPos": {
        "h": 5,
        "w": 6,
        "x": 18,
        "y": 14
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "noValue": "0",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green"
              },
              {
                "color": "yellow",
                "value": 80
              },
              {
                "color": "red",
                "value": 95
              }
            ]
          }
        }
      },
      "options": {
        "colorMode": "value",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "textMode": "value_and_name"
      },
      "targets": [
        {
          "expr": "sum(cnpg_backends_total{datname=\"tbite\",state=\"active\"})",
          "legendFormat": "pg active",
          "refId": "A"
        },
        {
          "expr": "redis_connected_clients",
          "legendFormat": "redis clients",
          "refId": "B"
        }
      ],
      "links": [
        {
          "title": "Infra Health",
          "url": "/d/infra-health",
          "targetBlank": false
        }
      ]
    },
    {
      "type": "row",
      "title": "What's slow / failing right now",
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 19
      },
      "collapsed": false
    },
    {
      "type": "table",
      "title": "\ud83d\udd25 Top failing endpoints \u2014 route \u00d7 status (5m)",
      "datasource": {
        "type": "prometheus",
        "uid": "VictoriaMetrics"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 20
      },
      "description": "Sort by 5xx column first \u2014 those are server bugs needing oncall. 4xx (especially 409) are client conflicts; expected during heavy contention.",
      "fieldConfig": {
        "defaults": {
          "custom": {
            "align": "left"
          }
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "5xx/s"
            },
            "properties": [
              {
                "id": "unit",
                "value": "ops"
              },
              {
                "id": "decimals",
                "value": 2
              },
              {
                "id": "custom.cellOptions",
                "value": {
                  "type": "color-background"
                }
              },
              {
                "id": "thresholds",
                "value": {
                  "mode": "absolute",
                  "steps": [
                    {
                      "color": "green"
                    },
                    {
                      "color": "red",
                      "value": 0.01
                    }
                  ]
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "4xx/s"
            },
            "properties": [
              {
                "id": "unit",
                "value": "ops"
              },
              {
                "id": "decimals",
                "value": 2
              },
              {
                "id": "custom.cellOptions",
                "value": {
                  "type": "color-background"
                }
              },
              {
                "id": "thresholds",
                "value": {
                  "mode": "absolute",
                  "steps": [
                    {
                      "color": "green"
                    },
                    {
                      "color": "yellow",
                      "value": 1
                    },
                    {
                      "color": "orange",
                      "value": 10
                    }
                  ]
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "total/s"
            },
            "properties": [
              {
                "id": "unit",
                "value": "ops"
              },
              {
                "id": "decimals",
                "value": 2
              }
            ]
          }
        ]
      },
      "options": {
        "showHeader": true,
        "sortBy": [
          {
            "displayName": "5xx/s",
            "desc": true
          },
          {
            "displayName": "4xx/s",
            "desc": true
          }
        ]
      },
      "targets": [
        {
          "expr": "sum by (http_route) (rate(http_server_request_duration_seconds_count{http_response_status_code=~\"5..\"}[5m]))",
          "instant": true,
          "format": "table",
          "refId": "A",
          "legendFormat": "5xx"
        },
        {
          "expr": "sum by (http_route) (rate(http_server_request_duration_seconds_count{http_response_status_code=~\"4..\"}[5m]))",
          "instant": true,
          "format": "table",
          "refId": "B",
          "legendFormat": "4xx"
        },
        {
          "expr": "sum by (http_route) (rate(http_server_request_duration_seconds_count[5m]))",
          "instant": true,
          "format": "table",
          "refId": "C",
          "legendFormat": "total"
        }
      ],
      "transformations": [
        {
          "id": "joinByField",
          "options": {
            "byField": "http_route",
            "mode": "outer"
          }
        },
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Time 1": true,
              "Time 2": true,
              "Time 3": true
            },
            "renameByName": {
              "http_route": "route",
              "Value #A": "5xx/s",
              "Value #B": "4xx/s",
              "Value #C": "total/s"
            },
            "indexByName": {
              "route": 0,
              "5xx/s": 1,
              "4xx/s": 2,
              "total/s": 3
            }
          }
        },
        {
          "id": "filterByValue",
          "options": {
            "filters": [
              {
                "fieldName": "5xx/s",
                "config": {
                  "id": "greater",
                  "options": {
                    "value": 0
                  }
                }
              },
              {
                "fieldName": "4xx/s",
                "config": {
                  "id": "greater",
                  "options": {
                    "value": 0
                  }
                }
              }
            ],
            "match": "any",
            "type": "include"
          }
        }
      ],
      "links": [
        {
          "title": "Service Health",
          "url": "/d/oncall-overview",
          "targetBlank": false
        }
      ]
    },
    {
      "type": "table",
      "title": "\ud83c\udf74 Hottest supply bottlenecks (rate of quota exhaustion)",
      "datasource": {
        "type": "prometheus",
        "uid": "VictoriaMetrics"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 20
      },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "align": "left"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green"
              },
              {
                "color": "yellow",
                "value": 1
              },
              {
                "color": "red",
                "value": 10
              }
            ]
          },
          "noValue": "no quota crunch \u2713"
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "Value"
            },
            "properties": [
              {
                "id": "unit",
                "value": "ops"
              },
              {
                "id": "displayName",
                "value": "quota-exhausted/s"
              },
              {
                "id": "decimals",
                "value": 2
              },
              {
                "id": "custom.cellOptions",
                "value": {
