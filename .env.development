# Canonical local development baseline. Copy selective overrides into .env.local.

# Shared dev stack identity
DEV_STACK_PROJECT_NAME=corporate-catering-local

# Runtime service
PRELAUNCH_BIND_ADDR=127.0.0.1:18080
PRELAUNCH_VENDOR_ID=ven-load-gate-a
PRELAUNCH_PLANT_ID=fab-a
PRELAUNCH_MENU_VARIANT_COUNT=64
PRELAUNCH_RECOMMENDATION_ENGINE_ENABLED=false
PRELAUNCH_ADVANCED_ANALYTICS_DASHBOARD_ENABLED=true
PRELAUNCH_RUSH_REMINDER_ENABLED=true
PRELAUNCH_RUSH_PREORDER_MIN_LEAD_DAYS=1
PRELAUNCH_RUSH_PREORDER_MAX_LEAD_DAYS=7
PRELAUNCH_RUSH_PREORDER_THROTTLE_MINUTES=60
PRELAUNCH_RUSH_DEMAND_SPIKE_REMAINING_THRESHOLD=5
PRELAUNCH_RUSH_DEMAND_SPIKE_THROTTLE_MINUTES=30
PRELAUNCH_AUDIT_TRAIL_PATH=ops/state/audit-trail.json
PRELAUNCH_AUDIT_TRAIL_ENCRYPTION_KEY_HEX=3f86c4af7284e37f0cd9aa8e1e5afef3f86c4af7284e37f0cd9aa8e1e5afef3
PRELAUNCH_PAYROLL_EXPORT_ENCRYPTION_KEY_HEX=7ac2f1ee8d95b4c37611a0d55ab2cc217ac2f1ee8d95b4c37611a0d55ab2cc21
PRELAUNCH_PICKUP_TOTP_SECRET=corporate-catering-local-pickup-secret

# Telemetry bootstrap (hard-required by runtime)
OTEL_EXPORTER_OTLP_ENDPOINT=http://127.0.0.1:4317
OTEL_SERVICE_NAME=catering-http-api
OTEL_SERVICE_NAMESPACE=corporate-catering
DEPLOYMENT_ENVIRONMENT=development

# MCP OAuth service-account baseline for local testing
MCP_OAUTH_SERVICE_ACCOUNT_ISSUER=https://local.catering.dev
MCP_OAUTH_SERVICE_ACCOUNT_AUDIENCE=corporate-catering-mcp-runtime
MCP_OAUTH_SERVICE_ACCOUNT_HS256_SECRET_BASE64=bWNwLW9hdXRoLWxvY2FsLXNpZ25pbmctc2VjcmV0LTMyeQ==
MCP_BRIDGE_KEY_REGISTRY_JSON='[{"keyId":"bridge-local-dev","issuedAtEpochSeconds":1700000000,"expiresAtEpochSeconds":4102444800,"rotatedAtEpochSeconds":1700000000,"allowedServiceAccountIds":["svc-local-dev"]}]'

# Core stateful dependencies
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5432
POSTGRES_DB=corporate_catering
POSTGRES_USER=corporate_catering
POSTGRES_PASSWORD=corporate_catering
DATABASE_URL=postgresql://corporate_catering:corporate_catering@127.0.0.1:5432/corporate_catering
PRELAUNCH_DB_POOL_MAX_CONNECTIONS=32
PRELAUNCH_DB_POOL_MIN_CONNECTIONS=4
PRELAUNCH_DB_POOL_ACQUIRE_TIMEOUT_MS=5000
PRELAUNCH_DB_POOL_IDLE_TIMEOUT_SECONDS=300
PRELAUNCH_DB_POOL_MAX_LIFETIME_SECONDS=1800

REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_URL=redis://127.0.0.1:6379

MINIO_PORT=9000
MINIO_ENDPOINT=127.0.0.1:${MINIO_PORT}
MINIO_CONSOLE_PORT=9001
MINIO_ROOT_USER=corporate-catering
MINIO_ROOT_PASSWORD=corporate-catering-dev
MINIO_BUCKET_MENU_IMAGES=menu-assets
MINIO_BUCKET_COMPLIANCE_EVIDENCE=compliance-evidence
MINIO_BUCKET_FULFILLMENT_EXPORTS=fulfillment-exports
OBJECT_STORAGE_REGION=us-east-1
OBJECT_STORAGE_KEY_NAMESPACE=corporate-catering
