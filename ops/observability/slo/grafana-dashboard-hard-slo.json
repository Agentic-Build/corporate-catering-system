{
  "id": null,
  "uid": "corporate-catering-hard-slo",
  "title": "Corporate Catering Hard SLO Gate",
  "tags": ["hard-slo", "release-gate", "corporate-catering"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 2,
  "refresh": "30s",
  "panels": [
    {
      "id": 1,
      "title": "Hard SLO: Order API Availability",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "victoriametrics" },
      "targets": [
        {
          "refId": "A",
          "expr": "100 * (sum(rate(http_server_requests_total{service_name=\"catering-http-api\",operation_id=\"createEmployeeOrder\",status_code!~\"5..\"}[5m])) / sum(rate(http_server_requests_total{service_name=\"catering-http-api\",operation_id=\"createEmployeeOrder\"}[5m])))",
          "legendFormat": "availability %"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "green", "value": 99.9 }
            ]
          }
        },
        "overrides": []
      }
    },
    {
      "id": 2,
      "title": "Hard SLO: Order API P95 Latency",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "victoriametrics" },
      "targets": [
        {
          "refId": "A",
          "expr": "histogram_quantile(0.95, sum by (le) (rate(http_server_request_duration_ms_bucket{service_name=\"catering-http-api\",operation_id=\"createEmployeeOrder\"}[5m])))",
          "legendFormat": "p95 latency ms"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 350 }
            ]
          }
        },
        "overrides": []
      }
    },
    {
      "id": 5,
      "title": "Hard SLO: Order API P99 Latency",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "victoriametrics" },
      "targets": [
        {
          "refId": "A",
          "expr": "histogram_quantile(0.99, sum by (le) (rate(http_server_request_duration_ms_bucket{service_name=\"catering-http-api\",operation_id=\"createEmployeeOrder\"}[5m])))",
          "legendFormat": "p99 latency ms"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 500 }
            ]
          }
        },
        "overrides": []
      }
    },
    {
      "id": 3,
      "title": "Hard SLO: Error Budget Burn Ratio",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "victoriametrics" },
      "targets": [
        {
          "refId": "A",
          "expr": "((1 - (sum(rate(http_server_requests_total{service_name=\"catering-http-api\",operation_id=\"createEmployeeOrder\",status_code!~\"5..\"}[1h])) / sum(rate(http_server_requests_total{service_name=\"catering-http-api\",operation_id=\"createEmployeeOrder\"}[1h])))) / (1 - 0.999))",
          "legendFormat": "burn ratio"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 2 }
            ]
          }
        },
        "overrides": []
      }
    },
    {
      "id": 4,
      "title": "Kubernetes Readiness Success Ratio",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "victoriametrics" },
      "targets": [
        {
          "refId": "A",
          "expr": "avg_over_time(kube_pod_status_ready{namespace=\"catering-prod\",condition=\"true\",pod=~\"corporate-catering-api-.*\"}[10m])",
          "legendFormat": "readiness ratio"
        }
      ]
    }
  ],
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": { "type": "grafana", "uid": "-- Grafana --" },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  }
}
