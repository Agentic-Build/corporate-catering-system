{
  "annotations": {
    "list": []
  },
  "description": "Developer-loop dashboard \u2014 recent traces, errors, slow queries. Intended for local/dev only. Use Explore drilldowns from each panel.",
  "editable": false,
  "graphTooltip": 1,
  "id": null,
  "panels": [
    {
      "type": "logs",
      "title": "Recent ERROR-level application logs",
      "datasource": {
        "type": "victoriametrics-logs-datasource",
        "uid": "victoria-logs"
      },
      "gridPos": {
        "h": 12,
        "w": 24,
        "x": 0,
        "y": 0
      },
      "options": {
        "showTime": true,
        "wrapLogMessage": true,
        "showLabels": true,
        "sortOrder": "Descending"
      },
      "targets": [
        {
          "expr": "_stream_id:* level:ERROR",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "HTTP request rate (all routes)",
      "datasource": {
        "type": "prometheus",
        "uid": "victoria-metrics"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 12
      },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 10,
            "showPoints": "never"
          }
        }
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": [
            "mean",
            "max"
          ]
        }
      },
      "targets": [
        {
          "expr": "sum by (http_route) (rate(http_server_request_duration_seconds_count[1m]))",
          "legendFormat": "{{http_route}}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Slow Postgres queries (top 10 by mean exec time)",
      "datasource": {
        "type": "prometheus",
        "uid": "victoria-metrics"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 12
      },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 10,
            "showPoints": "never"
          }
        }
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": [
            "mean",
            "max"
          ]
        }
      },
      "targets": [
        {
          "expr": "topk(10, pg_stat_statements_mean_exec_seconds)",
          "legendFormat": "{{queryid}}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "table",
      "title": "Recent traces \u2014 explore via right-click",
      "datasource": {
        "type": "jaeger",
        "uid": "victoria-traces"
      },
      "gridPos": {
        "h": 10,
        "w": 24,
        "x": 0,
        "y": 20
      },
      "options": {
        "showHeader": true
      },
      "targets": [
        {
          "query": "tbite-api",
          "queryType": "search",
          "refId": "A"
        }
      ]
    },
    {
      "type": "text",
      "title": "Helpful links",
      "gridPos": {
        "h": 4,
        "w": 24,
        "x": 0,
        "y": 30
      },
      "options": {
        "mode": "markdown",
        "content": "- **OTel Collector**: http://localhost:13133/ (health) \u00b7 http://localhost:8888/metrics\n- **VictoriaMetrics**: http://localhost:8428/vmui\n- **VictoriaLogs**: http://localhost:9428/select/vmui\n- **VictoriaTraces**: http://localhost:10428/\n- **vmalert**: http://localhost:8880\n- **Alertmanager**: http://localhost:9093\n- **MinIO**: http://localhost:9001\n- **Authentik**: http://localhost:9002\n"
      },
      "targets": []
    }
  ],
  "refresh": "10s",
  "schemaVersion": 39,
  "tags": [
    "dev",
    "local"
  ],
  "templating": {
    "list": []
  },
  "time": {
    "from": "now-30m",
    "to": "now"
  },
  "timezone": "browser",
  "title": "Dev Loop",
  "uid": "dev-loop",
  "version": 1,
  "links": [
    {
      "title": "\u2605 System Status",
      "type": "link",
      "url": "/d/status",
      "icon": "external link",
      "targetBlank": false
    },
    {
      "title": "\u25c6 Service Health",
      "type": "link",
      "url": "/d/oncall-overview",
      "icon": "external link",
      "targetBlank": false
    }
  ]
}