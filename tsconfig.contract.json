  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "noEmit": true,
    "skipLibCheck": false,
    "allowSyntheticDefaultImports": true
  },
  "include": [
    "generated/ts-client/**/*.ts",
    "contract-client-compile-check.ts"
  ]
}
