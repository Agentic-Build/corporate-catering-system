# T-Bite host-side env example. The canonical runtime is the Helm chart on
# Kubernetes; use these values only for local CLI tools or temporary
# port-forwarded processes that need to talk to that cluster.

# --- Go API runtime ---
HTTP_ADDR=:8080
LOG_LEVEL=info

# Required: Postgres + Redis. Fill these from Kubernetes secrets or
# port-forwards; there is no baked-in local default.
DATABASE_URL=postgres://tbite:change-me@127.0.0.1:5432/tbite?sslmode=disable
DATABASE_RW_URL=postgres://tbite:change-me@127.0.0.1:5432/tbite?sslmode=disable
# Optional read replica; empty falls back to DATABASE_RW_URL (config.go:255).
DATABASE_RO_URL=
# pgxpool sizing per role (config.go:110-113 defaults: max=16, min=2).
DB_MAX_CONNS=16
DB_MIN_CONNS=2
DB_MAX_CONNS_RO=16
DB_MIN_CONNS_RO=2
REDIS_URL=redis://:change-me@127.0.0.1:6379/0
NATS_URL=nats://127.0.0.1:4222
# JetStream stream replica count (config.go:142 default 1; 3 for clustered prod).
NATS_STREAM_REPLICAS=1

# --- OIDC provider registry ---
OIDC_CALLBACK_BASE_URL=http://api.tbite.local
AUTH_PROVIDER_SLUGS=authentik
AUTH_PROVIDER_AUTHENTIK_DISPLAY_NAME=Authentik
AUTH_PROVIDER_AUTHENTIK_ISSUER_URL=http://auth.tbite.local/application/o/tbite/
AUTH_PROVIDER_AUTHENTIK_CLIENT_ID=tbite-local
AUTH_PROVIDER_AUTHENTIK_CLIENT_SECRET=change-me
AUTH_PROVIDER_AUTHENTIK_SCOPES=openid email profile tbite

# --- Authentik management API (vendor operator provisioning) ---
AUTHENTIK_BASE_URL=http://auth.tbite.local
AUTHENTIK_API_TOKEN=change-me
AUTHENTIK_VENDOR_OPERATOR_GROUP=tbite:role:vendor_operator

# --- Per-app SPA base URLs (used to build post-login redirect) ---
APP_BASE_URL_EMPLOYEE=http://app.tbite.local
APP_BASE_URL_MERCHANT=http://merchant.tbite.local
APP_BASE_URL_ADMIN=http://admin.tbite.local

# --- Ory Hydra (OAuth 2.1 + Dynamic Client Registration for MCP) ---
# Only required when you want Claude.ai / ChatGPT remote MCP to self-register.
# Empty values disable the bridge and PRM falls back to advertising Authentik
# directly (bearer-token-paste only, no DCR).
HYDRA_PUBLIC_URL=http://hydra.tbite.local
HYDRA_ADMIN_URL=http://127.0.0.1:4445

# --- MCP stdio role (mcp-stdio) ---
# Required when running the binary with --role=mcp-stdio (main.go:542).
MCP_BEARER_TOKEN=change-me

# --- Recommendation tuning ---
# Blend factor for popularity vs personal-affinity scoring (main.go:393-399 default 1.0).
RECOMMENDATION_ALPHA=1.0

# --- S3-compatible object storage ---
S3_ENDPOINT=http://minio.tbite.local
S3_REGION=us-east-1
S3_ACCESS_KEY_ID=change-me
S3_SECRET_ACCESS_KEY=change-me
S3_BUCKET=tbite-dev
S3_USE_PATH_STYLE=1
# Public base URL for browser-direct MinIO access (path-style: {base}/{bucket}/{key}).
S3_PUBLIC_BASE_URL=http://minio.tbite.local
