# T-Bite local-dev env baseline. Copy to .env.local and fill in real values.
# Loaded only via shell export — scripts/dev/dev-app.sh inherits from the
# current shell. `make dev-up` (k3d) reads secrets from
# ops/kubernetes/overlays/single-node/secrets-bootstrap.yaml instead.

# --- Go API runtime ---
HTTP_ADDR=:8080
LOG_LEVEL=info

# Required: Postgres + Redis. NATS is optional for the API role.
DATABASE_RW_URL=postgres://tbite:tbite@127.0.0.1:5432/tbite?sslmode=disable
REDIS_URL=redis://127.0.0.1:6379
NATS_URL=nats://127.0.0.1:4222

# --- OIDC (leave blank to disable; fake provider is used in single-node k3d) ---
OIDC_GOOGLE_CLIENT_ID=
OIDC_GOOGLE_CLIENT_SECRET=
OIDC_GITHUB_CLIENT_ID=
OIDC_GITHUB_CLIENT_SECRET=
OIDC_CALLBACK_BASE_URL=http://api.tbite.test

# --- Per-app SPA base URLs (used to build post-login redirect) ---
APP_BASE_URL_EMPLOYEE=http://app.tbite.test
APP_BASE_URL_MERCHANT=http://merchant.tbite.test
APP_BASE_URL_ADMIN=http://admin.tbite.test

# --- S3-compatible object storage (only the payroll-settler worker needs it) ---
S3_ENDPOINT=http://127.0.0.1:9000
S3_REGION=us-east-1
S3_ACCESS_KEY_ID=tbite
S3_SECRET_ACCESS_KEY=tbite-dev-secret
S3_BUCKET=tbite
S3_USE_PATH_STYLE=1
