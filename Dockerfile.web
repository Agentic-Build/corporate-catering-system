FROM node:22-bookworm-slim AS build

RUN npm install -g pnpm@8.15.6

ARG MOCK_AUTH_SIGNING_SECRET
WORKDIR /work/apps/web

COPY apps/web/package.json apps/web/pnpm-lock.yaml ./

RUN pnpm install

WORKDIR /work

COPY apps/web ./apps/web
COPY contract ./contract

WORKDIR /work/apps/web

RUN MOCK_AUTH_SIGNING_SECRET="${MOCK_AUTH_SIGNING_SECRET}" pnpm run build

FROM node:22-bookworm-slim

RUN npm install -g pnpm@8.15.6 \
    && useradd --system --uid 65532 --home-dir /app --create-home --shell /usr/sbin/nologin app

WORKDIR /app

COPY --from=build /work/apps/web/package.json /work/apps/web/pnpm-lock.yaml ./

RUN pnpm install --prod

COPY --from=build /work/apps/web/build ./build

USER 65532:65532

CMD ["node", "build"]
